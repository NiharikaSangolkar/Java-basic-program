//Find Sum & Average of Array
import java.util.*;
public class countevenodd{
    public static void main(String[]args)
    {
        int arr[]={1,2,3,5,6};
        int sum=0;
        double avg=0;
        for(int i=0;i<arr.length;i++)
        {
            sum+=arr[i];
            
        }
        avg=(double)sum/arr.length;
        System.out.println("sum:"+sum);
        System.out.println("avg:"+avg);
        
}
}
